{
  "name": "library-api",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "wrangler dev",
    "db:create": "wrangler d1 create library-db",
    "db:init:local": "wrangler d1 execute library-db --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute library-db --remote --file=./schema.sql",
    "secret": "wrangler secret put LIBRARY_TOKEN",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "wrangler": "4.103.0"
  }
}
