{
  "name": "library-api",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "check": "node --check src/index.js && node --check ../../apps/web/assets/js/app.js && node --check ../../apps/web/assets/js/library-api-client.js",
    "test": "node --test test/*.test.js",
    "typecheck": "node --check src/index.js",
    "build": "wrangler deploy --dry-run --outdir dist",
    "db:create": "wrangler d1 create library-db",
    "db:init:local": "wrangler d1 execute library-db --local --file=./migrations/0001_initial.sql",
    "db:init:remote": "wrangler d1 execute library-db --remote --file=./migrations/0001_initial.sql",
    "db:migrate:local": "wrangler d1 migrations apply library-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply library-db --remote",
    "db:migrate:postgres": "node scripts/migrate.js",
    "db:seed:postgres": "node scripts/seed.js",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@fastify/static": "9.1.3",
    "fastify": "5.8.5",
    "postgres": "3.4.9"
  },
  "devDependencies": {
    "wrangler": "4.103.0"
  }
}
